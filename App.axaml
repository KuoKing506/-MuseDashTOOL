<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MdModManager.App"
             xmlns:local="using:MdModManager"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <!-- 全局移除 TextBox 聚焦时的蓝色边框与阴影 -->
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeTextTertiaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeTextSubBrush}" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource SvgIconBrush}" />
        </Style>

        <!-- 修复滚动条残留线问题：激进清理方案 -->
        <Style Selector="ScrollBar">
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Background" Value="#01000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Transitions" Value="{x:Null}" />
        </Style>
        <!-- 隐藏滚动条两端的箭头按钮 -->
        <Style Selector="ScrollBar /template/ RepeatButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <!-- 简化滑块模板，避免复杂动画和边框产生的残留虚影 -->
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource SvgIconBrush}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="4" 
                            Margin="2" 
                            BorderThickness="0" />
                </ControlTemplate>
            </Setter>
        </Style>
        <!-- 全局强制裁剪 -->
        <Style Selector="ScrollViewer">
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ColorPaletteResources x:Key="Dark" Accent="#d4237a" RegionColor="#1E1E1E" ErrorText="Red" />
    </Application.Resources>
</Application>