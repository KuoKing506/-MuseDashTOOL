<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MdModManager.Views.EasterEggWindow"
        Title="EasterEgg"
        Width="600" Height="200"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        IsHitTestVisible="False">
    <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0"
            Background="#FF1493" Opacity="0.9"
            CornerRadius="15" Padding="40,20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="#FF1493" Opacity="0.5"/>
        </Border.Effect>
        <TextBlock x:Name="MessageText" 
                   FontSize="26" FontWeight="Bold" Foreground="White" 
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
</Window>
