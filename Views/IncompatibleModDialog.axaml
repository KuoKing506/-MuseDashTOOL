<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MdModManager.Views.IncompatibleModDialog"
        Title="下载不兼容 Mod" 
        Width="480" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White">

    <Grid RowDefinitions="*, Auto" Margin="24">

        <!-- 提示文本 -->
        <TextBlock Grid.Row="0"
                   Text="该 mod 根据版本号判断不兼容，但并不一定完全不可用，如果下载使用可能会造成游戏无法打开、影响其他 mod 功能等问题，确定下载使用吗？"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Foreground="#E0E0E0"
                   VerticalAlignment="Center"/>

        <!-- 底部按钮区 -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto, 10, Auto" Margin="0,16,0,0">

            <!-- 左下角：不再提示复选框 -->
            <CheckBox Grid.Column="0"
                      x:Name="DontShowAgainCheckBox"
                      Content="不再显示此提示"
                      Foreground="Gray"
                      FontSize="13"/>

            <!-- 右下角：取消 / 确认 -->
            <Button Grid.Column="2"
                    Content="取消"
                    Width="80"
                    HorizontalContentAlignment="Center"
                    Background="#333333" Foreground="White"
                    Click="OnCancelClick"/>

            <Button Grid.Column="4"
                    Content="确认"
                    Width="90"
                    HorizontalContentAlignment="Center"
                    Background="#FF00FF" Foreground="White"
                    Click="OnConfirmClick"/>
        </Grid>
    </Grid>
</Window>
